<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Estilo de la tarjeta de partido -->
    <style name="PartidoCard">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <!-- Para quitar el tinte de Material al fondo -->
        <item name="backgroundTint">@null</item>
    </style>

    <!-- Estilo del nombre de los equipos -->
    <style name="EquiposText">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
        <item name="android:ellipsize">end</item>
    </style>

    <!-- Estilo del texto del marcador -->
    <style name="MarcadorText">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <!-- Estilo para el día y hora -->
    <style name="DiaHoraText">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">?attr/colorSecondary</item>
    </style>

    <!-- Estilo para la sede -->
    <style name="SedeText">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">italic</item>
        <item name="android:textColor">?attr/colorSecondary</item>
    </style>

</resources>